server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # Suporte para roteamento do SPA do Jellyfin
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Otimização de cache
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|otf)$ {
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }
}
